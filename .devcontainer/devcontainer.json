{
	"name": "Stack Trace Analyzer Development",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "22"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"Orta.vscode-jest"
			]
		}
	},
	"postCreateCommand": "npm install -g @vscode/vsce prettier && npm install && echo 'Development environment ready!'",
	"remoteUser": "vscode",
	"mounts": [
		"source=${localWorkspaceFolder}/.git,target=/workspaces/${localWorkspaceFolderBasename}/.git,type=bind,consistency=cached"
	]
}
